---
import Layout from '../layouts/Layout.astro'
import Breadcrumb from '../components/ui/Breadcrumb.astro'
import Servicios from '../components/sections/Servicios.astro'
---

<Layout
  title="Servicios"
  description="Servicios técnicos en instrumentación, automatización, electrónica industrial, calibración y mantenimiento."
>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Servicios' }
    ]}
    title="Servicios"
    backgroundImage="https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=1600&q=80"
  />

  <Servicios />

  <!-- CTA final -->
  <section class="py-28 bg-[#0E2346] text-white">
    <div class="max-w-5xl mx-auto px-10 text-center">
      <p class="text-[#F47920] text-sm font-medium uppercase tracking-[0.22em] mb-7">
        ¿Necesitas algo específico?
      </p>
      <h2 class="text-white font-semibold mb-8" style="font-size: 42px; line-height: 1.1; letter-spacing: -0.025em;">
        Conversemos sobre tu proyecto
      </h2>
      <p class="text-white/75 font-light mb-12 max-w-2xl mx-auto" style="font-size: 1.15rem; line-height: 1.7;">
        Nuestro equipo técnico está disponible para analizar tus requerimientos y proponer la mejor solución.
      </p>
      <div class="flex gap-6 justify-center flex-wrap">
        <a href="/contacto" class="bg-[#F47920] hover:bg-[#d96a10] text-white font-medium text-base tracking-wide px-10 py-5 transition-colors rounded-[2px]">
          Solicitar cotización
        </a>
        <a href="/productos" class="inline-flex items-center gap-2.5 text-white font-normal text-base tracking-wide px-3 py-5 hover:gap-4 transition-all">
          Ver catálogo de productos
          <span class="text-[#F47920] text-lg">→</span>
        </a>
      </div>
    </div>
  </section>

</Layout>
