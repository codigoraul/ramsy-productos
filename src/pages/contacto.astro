---
import Layout from '../layouts/Layout.astro'
import Breadcrumb from '../components/ui/Breadcrumb.astro'
---

<Layout 
  title="Contacto" 
  description="Contáctanos para cotizaciones, asesoría técnica o consultas sobre nuestros productos y servicios."
>
  <Breadcrumb 
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Contacto' }
    ]}
    title="Contacto"
    backgroundImage="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1600&q=80"
  />

  <section class="py-20 bg-white">
    <div class="max-w-[1400px] mx-auto px-10">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Columna izquierda: Info -->
        <div>
          <p class="text-[#F47920] text-sm font-medium uppercase tracking-[0.22em] mb-7">
            Hablemos
          </p>
          <h2 class="text-[#0E2346] font-semibold mb-8" style="font-size: 42px; line-height: 1.08; letter-spacing: -0.025em;">
            Estamos para ayudarte
          </h2>
          <p class="text-gray-600 font-light leading-[1.7] mb-12" style="font-size: 1.15rem;">
            Nuestro equipo técnico está disponible para asesorarte en la selección de productos, cotizaciones y soporte técnico especializado.
          </p>

          <!-- Información de contacto -->
          <div class="space-y-8">
            
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-[#F5F5F0] flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F47920]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-[#0E2346] font-medium mb-2" style="font-size: 1.1rem;">
                  Dirección
                </h3>
                <p class="text-gray-600 font-light leading-[1.6]">
                  Las Madreselvas 5052<br />
                  La Serena, Chile
                </p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-[#F5F5F0] flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F47920]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-[#0E2346] font-medium mb-2" style="font-size: 1.1rem;">
                  Teléfono
                </h3>
                <p class="text-gray-600 font-light leading-[1.6]">
                  <a href="tel:+56900000000" class="hover:text-[#F47920] transition-colors">
                    +56 9 XXXX XXXX
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-[#F5F5F0] flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F47920]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-[#0E2346] font-medium mb-2" style="font-size: 1.1rem;">
                  Email
                </h3>
                <p class="text-gray-600 font-light leading-[1.6]">
                  <a href="mailto:contacto@ramsy.cl" class="hover:text-[#F47920] transition-colors">
                    contacto@ramsy.cl
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-[#F5F5F0] flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F47920]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-[#0E2346] font-medium mb-2" style="font-size: 1.1rem;">
                  Horario de atención
                </h3>
                <p class="text-gray-600 font-light leading-[1.6]">
                  Lunes a Viernes<br />
                  09:00 – 18:00 hrs
                </p>
              </div>
            </div>

          </div>
        </div>

        <!-- Columna derecha: Formulario -->
        <div class="bg-[#F5F5F0] p-10 lg:p-12">
          <h2 class="text-[#0E2346] font-semibold mb-3" style="font-size: 42px; line-height: 1.08; letter-spacing: -0.025em;">
            Envíanos un mensaje
          </h2>
          <p class="text-gray-600 font-light mb-8" style="font-size: 1.05rem;">
            Completa el formulario y te responderemos a la brevedad.
          </p>

          <form class="space-y-6">
            
            <div>
              <label for="nombre" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Nombre completo *
              </label>
              <input 
                type="text" 
                id="nombre" 
                name="nombre" 
                required
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light"
                placeholder="Juan Pérez"
              />
            </div>

            <div>
              <label for="email" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Email *
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light"
                placeholder="juan@empresa.cl"
              />
            </div>

            <div>
              <label for="telefono" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Teléfono
              </label>
              <input 
                type="tel" 
                id="telefono" 
                name="telefono"
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light"
                placeholder="+56 9 XXXX XXXX"
              />
            </div>

            <div>
              <label for="empresa" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Empresa
              </label>
              <input 
                type="text" 
                id="empresa" 
                name="empresa"
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light"
                placeholder="Nombre de tu empresa"
              />
            </div>

            <div>
              <label for="asunto" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Asunto *
              </label>
              <select 
                id="asunto" 
                name="asunto" 
                required
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light"
              >
                <option value="">Selecciona un asunto</option>
                <option value="cotizacion">Solicitud de cotización</option>
                <option value="asesoria">Asesoría técnica</option>
                <option value="soporte">Soporte técnico</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div>
              <label for="mensaje" class="block text-[#0E2346] font-medium mb-2 text-sm tracking-wide">
                Mensaje *
              </label>
              <textarea 
                id="mensaje" 
                name="mensaje" 
                rows="5" 
                required
                class="w-full px-4 py-3.5 border border-gray-300 focus:border-[#F47920] focus:ring-1 focus:ring-[#F47920] outline-none transition-colors font-light resize-none"
                placeholder="Cuéntanos en qué podemos ayudarte..."
              ></textarea>
            </div>

            <button 
              type="submit"
              class="w-full bg-[#F47920] hover:bg-[#d96a10] text-white font-medium text-base tracking-wide py-4 transition-colors"
            >
              Enviar mensaje
            </button>

            <p class="text-gray-500 text-xs font-light text-center">
              * Campos obligatorios
            </p>

          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>
