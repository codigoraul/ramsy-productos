---
import Layout from '../layouts/Layout.astro'
import Breadcrumb from '../components/ui/Breadcrumb.astro'
---

<Layout title="Carrito de Compras" description="Revisa los productos en tu carrito de compras">
  
  <Breadcrumb 
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Carrito' }
    ]}
  />

  <section class="py-16 bg-white min-h-screen">
    <div class="max-w-[1200px] mx-auto px-10">
      
      <h1 class="text-[#0E2346] font-semibold mb-12" style="font-size: 42px; line-height: 1.08; letter-spacing: -0.025em;">
        Carrito de Compras
      </h1>

      <!-- Contenedor del carrito -->
      <div id="cart-container">
        <!-- Se llenará con JavaScript -->
      </div>

      <!-- Carrito vacío -->
      <div id="empty-cart" class="hidden text-center py-16">
        <svg class="w-24 h-24 text-gray-300 mx-auto mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <h2 class="text-2xl font-semibold text-gray-700 mb-4">Tu carrito está vacío</h2>
        <p class="text-gray-500 mb-8">Agrega productos para comenzar tu compra</p>
        <a href="/productos" class="inline-block bg-[#F47920] text-white px-8 py-3 font-medium hover:bg-[#d66a1a] transition-colors">
          Ver Productos
        </a>
      </div>

    </div>
  </section>

</Layout>

<script>
  // Cargar y mostrar el carrito
  function loadCart() {
    const cart = JSON.parse(localStorage.getItem('ramsy_cart') || '[]')
    const container = document.getElementById('cart-container')
    const emptyCart = document.getElementById('empty-cart')

    if (cart.length === 0) {
      container.classList.add('hidden')
      emptyCart.classList.remove('hidden')
      return
    }

    container.classList.remove('hidden')
    emptyCart.classList.add('hidden')

    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0)

    container.innerHTML = `
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Productos -->
        <div class="lg:col-span-2 space-y-4">
          ${cart.map(item => `
            <div class="flex gap-6 p-6 bg-white border border-gray-200 rounded-lg" data-item-id="${item.id}">
              <img src="${item.image}" alt="${item.name}" class="w-24 h-24 object-contain bg-gray-50 rounded" />
              
              <div class="flex-1">
                <h3 class="font-semibold text-lg text-[#0E2346] mb-2">
                  <a href="/productos/${item.slug}" class="hover:text-[#F47920] transition-colors">${item.name}</a>
                </h3>
                ${item.sku ? `<p class="text-sm text-gray-500 mb-3">SKU: ${item.sku}</p>` : ''}
                
                <div class="flex items-center gap-4">
                  <div class="flex items-center border border-gray-300 rounded">
                    <button class="qty-minus px-3 py-1 hover:bg-gray-100" data-id="${item.id}">-</button>
                    <span class="px-4 py-1 border-x border-gray-300">${item.quantity}</span>
                    <button class="qty-plus px-3 py-1 hover:bg-gray-100" data-id="${item.id}">+</button>
                  </div>
                  
                  <button class="remove-item text-red-600 hover:text-red-700 text-sm font-medium" data-id="${item.id}">
                    Eliminar
                  </button>
                </div>
              </div>
              
              <div class="text-right">
                <p class="text-2xl font-semibold text-[#0E2346]">
                  $${(item.price * item.quantity).toLocaleString('es-CL')}
                </p>
                <p class="text-sm text-gray-500 mt-1">
                  $${item.price.toLocaleString('es-CL')} c/u
                </p>
              </div>
            </div>
          `).join('')}
        </div>

        <!-- Resumen -->
        <div class="lg:col-span-1">
          <div class="bg-gray-50 p-6 rounded-lg sticky top-24">
            <h2 class="font-semibold text-[#0E2346]" style="font-size: 30px; margin-bottom: 34px;">Resumen del pedido</h2>
            
            <div class="space-y-3 mb-6 pb-6 border-b border-gray-200">
              <div class="flex justify-between text-gray-600">
                <span>Subtotal</span>
                <span>$${total.toLocaleString('es-CL')}</span>
              </div>
              <div class="flex justify-between text-gray-600">
                <span>Envío</span>
                <span>Por calcular</span>
              </div>
            </div>
            
            <div class="flex justify-between text-xl font-semibold text-[#0E2346] mb-6">
              <span>Total</span>
              <span>$${total.toLocaleString('es-CL')}</span>
            </div>
            
            <button id="checkout-btn" class="block w-full bg-[#F47920] text-white text-center px-6 py-4 font-medium hover:bg-[#d66a1a] transition-colors rounded mb-3">
              Pagar con WebPay Plus
            </button>
            
            <a href="/contacto" class="block w-full bg-gray-200 text-gray-700 text-center px-6 py-3 font-medium hover:bg-gray-300 transition-colors rounded text-sm">
              Solicitar Cotización
            </a>
            
            <a href="/productos" class="block w-full text-center text-gray-600 hover:text-[#0E2346] py-3 mt-4 transition-colors">
              Continuar comprando
            </a>
          </div>
        </div>

      </div>
    `

    // Event listeners para botones
    document.querySelectorAll('.qty-minus').forEach(btn => {
      btn.addEventListener('click', () => updateQuantity(btn.dataset.id, -1))
    })

    document.querySelectorAll('.qty-plus').forEach(btn => {
      btn.addEventListener('click', () => updateQuantity(btn.dataset.id, 1))
    })

    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', () => removeItem(btn.dataset.id))
    })
  }

  function updateQuantity(productId, change) {
    const cart = JSON.parse(localStorage.getItem('ramsy_cart') || '[]')
    const item = cart.find(i => i.id === productId)
    
    if (item) {
      item.quantity += change
      if (item.quantity <= 0) {
        removeItem(productId)
        return
      }
      localStorage.setItem('ramsy_cart', JSON.stringify(cart))
      window.dispatchEvent(new CustomEvent('cartUpdated', { detail: cart }))
      loadCart()
    }
  }

  function removeItem(productId) {
    let cart = JSON.parse(localStorage.getItem('ramsy_cart') || '[]')
    cart = cart.filter(item => item.id !== productId)
    localStorage.setItem('ramsy_cart', JSON.stringify(cart))
    window.dispatchEvent(new CustomEvent('cartUpdated', { detail: cart }))
    loadCart()
  }

  // Cargar al inicio
  loadCart()

  // Escuchar cambios
  window.addEventListener('cartUpdated', loadCart)

  // Manejar el botón de checkout
  function handleCheckout() {
    const checkoutBtn = document.getElementById('checkout-btn')
    
    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', async () => {
        const cart = JSON.parse(localStorage.getItem('ramsy_cart') || '[]')
        
        if (cart.length === 0) {
          alert('Tu carrito está vacío')
          return
        }

        // Mostrar loading
        checkoutBtn.disabled = true
        checkoutBtn.textContent = 'Procesando...'

        try {
          // Opción 1: Redirigir directamente al checkout de WooCommerce
          // Construir URL con los productos
          const wpUrl = import.meta.env.WP_URL || 'http://localhost:10033'
          
          // Agregar productos al carrito de WooCommerce vía URL
          const productIds = cart.map(item => `add-to-cart=${item.id}`).join('&')
          const quantities = cart.map((item, index) => `quantity[${index}]=${item.quantity}`).join('&')
          
          // Redirigir al checkout de WooCommerce
          window.location.href = `${wpUrl}/checkout/?${productIds}&${quantities}`
          
        } catch (error) {
          console.error('Error al procesar el checkout:', error)
          alert('Hubo un error al procesar tu pedido. Por favor, intenta nuevamente.')
          checkoutBtn.disabled = false
          checkoutBtn.textContent = 'Pagar con WebPay Plus'
        }
      })
    }
  }

  // Llamar después de cargar el carrito
  setTimeout(handleCheckout, 100)
</script>
