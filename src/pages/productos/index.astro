---
import Layout from '../../layouts/Layout.astro'
import Breadcrumb from '../../components/ui/Breadcrumb.astro'
import { getProductos, getCategorias, formatearPrecio, getImagenProducto } from '../../lib/woocommerce.js'

const base = import.meta.env.BASE_URL

const productos = await getProductos({ perPage: 20 })
const categorias = await getCategorias()
---

<Layout 
  title="Productos" 
  description="Catálogo de productos de instrumentación y electrónica industrial"
>
  <Breadcrumb 
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Productos' }
    ]}
    title="Productos"
    backgroundImage="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=1600&q=80"
  />

  <!-- Productos -->
  <section class="py-16 bg-white">
    <div class="max-w-[1200px] mx-auto px-10">
      
      <!-- Header -->
      <div class="mb-12">
        <p class="text-[#F47920] text-sm font-medium uppercase tracking-[0.22em] mb-4">
          Catálogo
        </p>
        <h2 class="text-[#0E2346] font-semibold mb-6">
          Nuestros productos
        </h2>
        <p class="text-gray-600 font-light leading-[1.7] max-w-3xl">
          Instrumentación y electrónica industrial de alta precisión para tu empresa.
        </p>
      </div>

      <!-- Filtros por categoría -->
      {categorias && categorias.length > 0 && (
        <div class="mb-12 pb-8 border-b border-gray-200">
          <div class="flex flex-wrap gap-3">
            <button class="categoria-filter active px-6 py-3 bg-[#F47920] text-white font-medium tracking-wide hover:bg-[#d66a1a] transition-colors" data-categoria="todas">
              Todas
            </button>
            {categorias.map(cat => (
              <button 
                class="categoria-filter px-6 py-3 bg-gray-100 text-gray-700 font-medium tracking-wide hover:bg-gray-200 transition-colors"
                data-categoria={cat.slug}
              >
                {cat.name}
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- Grid de productos -->
      {productos && productos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {productos.map(producto => {
            const precio = formatearPrecio(producto.price)
            const imagen = getImagenProducto(producto)
            const categoriaSlug = producto.categories?.[0]?.slug || ''
            
            return (
              <article 
                class="producto-card group bg-white border border-gray-200 hover:border-[#F47920] transition-all duration-300 hover:shadow-lg"
                data-categorias={categoriaSlug}
              >
                {/* Imagen */}
                <a href={`${base}/productos/${producto.slug}`} class="block bg-[#F5F5F0] p-6 overflow-hidden">
                  <img 
                    src={imagen} 
                    alt={producto.name}
                    class="w-full h-64 object-contain group-hover:scale-105 transition-transform duration-300"
                  />
                </a>

                {/* Info */}
                <div class="p-6">
                  {/* Categoría */}
                  {producto.categories && producto.categories.length > 0 && (
                    <p class="text-[#F47920] text-xs font-medium uppercase tracking-[0.2em] mb-3">
                      {producto.categories[0].name}
                    </p>
                  )}

                  {/* Nombre */}
                  <h3 class="text-[#0E2346] font-semibold mb-3 group-hover:text-[#F47920] transition-colors text-xl">
                    <a href={`${base}/productos/${producto.slug}`}>
                      {producto.name}
                    </a>
                  </h3>

                  {/* SKU */}
                  {producto.sku && (
                    <p class="text-gray-500 text-sm font-light mb-4">
                      SKU: {producto.sku}
                    </p>
                  )}

                  {/* Precio */}
                  <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                    <p class="text-[#0E2346] font-semibold text-2xl">
                      {precio}
                    </p>
                    
                    {/* Stock badge */}
                    {producto.stock_status === 'instock' ? (
                      <span class="text-green-600 text-xs font-medium px-3 py-1 bg-green-50 rounded-full">
                        En stock
                      </span>
                    ) : (
                      <span class="text-red-600 text-xs font-medium px-3 py-1 bg-red-50 rounded-full">
                        Sin stock
                      </span>
                    )}
                  </div>

                  {/* Botón */}
                  <a 
                    href={`${base}/productos/${producto.slug}`}
                    class="mt-4 block w-full text-center bg-[#F47920] text-white px-6 py-3 font-medium tracking-wide hover:bg-[#d66a1a] transition-colors"
                  >
                    Ver detalles
                  </a>
                </div>
              </article>
            )
          })}
        </div>
      ) : (
        <div class="text-center py-20">
          <svg class="w-20 h-20 text-gray-300 mx-auto mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
          </svg>
          <h3 class="text-[#0E2346] font-semibold mb-3 text-2xl">
            No hay productos disponibles
          </h3>
          <p class="text-gray-600 font-light mb-8">
            Estamos actualizando nuestro catálogo. Vuelve pronto.
          </p>
          <a href="/contacto" class="inline-block bg-[#F47920] text-white px-8 py-3 font-medium tracking-wide hover:bg-[#d66a1a] transition-colors">
            Contáctanos
          </a>
        </div>
      )}

    </div>
  </section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Filtro por categorías
  const filterButtons = document.querySelectorAll('.categoria-filter')
  const productCards = document.querySelectorAll('.producto-card')

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const categoria = button.getAttribute('data-categoria')
      
      // Update active button
      filterButtons.forEach(btn => {
        btn.classList.remove('active', 'bg-[#F47920]', 'text-white')
        btn.classList.add('bg-gray-100', 'text-gray-700')
      })
      button.classList.add('active', 'bg-[#F47920]', 'text-white')
      button.classList.remove('bg-gray-100', 'text-gray-700')
      
      // Filter products
      productCards.forEach(card => {
        if (categoria === 'todas') {
          card.style.display = 'block'
        } else {
          const categorias = card.getAttribute('data-categorias')
          if (categorias && categorias.includes(categoria)) {
            card.style.display = 'block'
          } else {
            card.style.display = 'none'
          }
        }
      })
    })
  })
</script>
