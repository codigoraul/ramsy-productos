---
const servicios = [
  {
    icono: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v10m0 0h10m-10 0a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m12 6a2 2 0 002-2v-4m0 0H9',
    titulo: 'Servicios e instalaciones',
    descripcion: 'Diseño y armado de tableros eléctricos. Armado de cables automotriz y de instrumentación y control.',
  },
  {
    icono: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    titulo: 'Tableros de faena',
    descripcion: 'Tableros de faena metálica y tableros de faena externos para operaciones industriales exigentes.',
  },
  {
    icono: 'M13 10V3L4 14h7v7l9-11h-7z',
    titulo: 'Tableros neumáticos',
    descripcion: 'Diseño, armado e instalación de tableros electroneumáticos para sistemas de control industrial.',
  },
  {
    icono: 'M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7M4 7c0-2 1-3 3-3h10c2 0 3 1 3 3M4 7h16M9 11v4m3-4v4m3-4v4',
    titulo: 'Armado de cables',
    descripcion: 'Armado de cables automotriz para maquinaria. Armado de cables de instrumentación y señales.',
  },
]
---

<section class="py-32 bg-white">
  <div class="max-w-[1200px] mx-auto px-8">

    <!-- Header sección — grande y refinado -->
    <div class="max-w-3xl mb-24">
      <p class="text-[#F47920] text-sm font-medium uppercase tracking-[0.22em] mb-7">
        Lo que hacemos
      </p>
      <h2 class="text-[#0E2346] font-semibold mb-7" style="font-size: 42px; line-height: 1.08; letter-spacing: -0.025em;">
        Capacidades técnicas integrales
      </h2>
      <p class="text-gray-500 font-light" style="font-size: clamp(1.1rem, 1.4vw, 1.3rem); line-height: 1.7;">
        Acompañamos cada proyecto desde el diagnóstico hasta la operación continua, con enfoque en la confiabilidad del proceso.
      </p>
    </div>

    <!-- Grid servicios -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      {servicios.map((servicio, i) => (
        <div class="group border-t border-gray-200 pt-10 transition-all duration-300">
          <span class="block text-[#F47920] text-sm font-medium tracking-[0.15em] mb-8">
            {String(i + 1).padStart(2, '0')}
          </span>

          <div class="w-12 h-12 flex items-center justify-center mb-7 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#1B3A6B] group-hover:text-[#F47920] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.25" d={servicio.icono} />
            </svg>
          </div>

          <h3 class="text-[#0E2346] font-semibold tracking-tight leading-snug mb-4" style="font-size: 1.5rem; letter-spacing: -0.015em;">
            {servicio.titulo}
          </h3>

          <p class="text-gray-500 font-light" style="font-size: 1.05rem; line-height: 1.7;">
            {servicio.descripcion}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-24">
      <a href="/servicios" class="inline-flex items-center gap-3 text-[#0E2346] font-medium text-base tracking-wide hover:gap-4 transition-all border-b border-[#0E2346] pb-2">
        Ver todos los servicios
        <span class="text-[#F47920] text-lg">→</span>
      </a>
    </div>

  </div>
</section>
