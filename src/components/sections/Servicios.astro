---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const servicios = [
  {
    id: "servicios-instalaciones",
    tag: "Instalaciones",
    nombre: "Servicios e instalaciones",
    imagen: `${base}/images/servicios/servicios-instalaciones.webp`,
    imagenAlt: "Servicio y reparación de herramientas eléctricas Makita",
    items: [
      "Diseño y armado de tableros eléctricos",
      "Armado de cables automotriz y de instrumentación y control",
      "Mantención y reparación de herramientas eléctricas Makita",
    ],
  },
  {
    id: "tableros-faena",
    tag: "Faena",
    nombre: "Tableros de faena",
    imagen: `${base}/images/servicios/tablero-faena-metalico.webp`,
    imagenAlt: "Tablero de faena metálico RAMSY",
    items: [
      "Tablero de faena metálico",
      "Tablero de faena estanco ABS",
    ],
  },
  {
    id: "tableros-neumaticos",
    tag: "Neumática",
    nombre: "Tableros neumáticos",
    imagen: `${base}/images/servicios/tableros-neumaticos.jpg`,
    imagenAlt: "Tableros electroneumáticos industriales",
    items: [
      "Tableros electroneumáticos",
    ],
  },
  {
    id: "armado-cables",
    tag: "Cableado",
    nombre: "Armado de cables",
    imagen: `${base}/images/servicios/armado-cables.jpg`,
    imagenAlt: "Armado de cables de instrumentación",
    items: [
      "Cables automotriz para maquinaria",
      "Cables de instrumentación y señales",
    ],
  },
]
---

<section class="servicios-section">
  <div class="servicios-container">

    <div class="servicios-header">
      <p class="servicios-eyebrow">Lo que hacemos</p>
      <h2 class="servicios-titulo">Servicio de mantenimiento y reparación de herramientas eléctricas Makita</h2>
    </div>

    <div class="servicios-grid">
      {servicios.map((s) => (
        <article class="srv-card">
          <div class="srv-img-wrap">
            <img src={s.imagen} alt={s.imagenAlt} loading="lazy" class="srv-img" />
          </div>
          <div class="srv-body">
            <span class="srv-tag">{s.tag}</span>
            <h3 class="srv-nombre">{s.nombre}</h3>
            <ul class="srv-items">
              {s.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .servicios-section {
    background-color: #F5F5F0;
    padding: 64px 0 80px;
  }

  .servicios-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .servicios-header {
    margin-bottom: 40px;
    text-align: center;
  }

  .servicios-eyebrow {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #F47920;
    margin-bottom: 10px;
  }

  .servicios-titulo {
    font-size: 32px;
    font-weight: 600;
    color: #0E2346;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .servicios-desc {
    font-size: 17px;
    color: #666;
    line-height: 1.7;
    max-width: 560px;
    font-weight: 300;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .srv-card {
    background: #ffffff;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid #e4e4e0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .srv-card:hover {
    box-shadow: 0 10px 32px rgba(14, 35, 70, 0.10);
    transform: translateY(-4px);
  }

  .srv-img-wrap {
    width: 100%;
    height: 270px;
    overflow: hidden;
    background: linear-gradient(135deg, #0E2346 0%, #1B3A6B 100%);
    flex-shrink: 0;
  }

  .srv-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .srv-card:hover .srv-img {
    transform: scale(1.04);
  }

  .srv-body {
    padding: 22px 22px 26px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .srv-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #FFF0E6;
    color: #C45F0A;
    padding: 3px 9px;
    border-radius: 3px;
    margin-bottom: 12px;
    align-self: flex-start;
  }

  .srv-nombre {
    font-size: 20px;
    font-weight: 600;
    color: #0E2346;
    margin-bottom: 14px;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .srv-items {
    list-style: none;
    flex: 1;
  }

  .srv-items li {
    font-size: 16px;
    color: #555;
    padding: 8px 0;
    border-bottom: 1px solid #f0f0ec;
    line-height: 1.5;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-weight: 300;
  }

  .srv-items li:last-child {
    border-bottom: none;
  }

  .srv-items li::before {
    content: '';
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #F47920;
    margin-top: 5px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .servicios-grid {
      grid-template-columns: 1fr;
    }
    .servicios-titulo {
      font-size: 24px;
    }
  }
</style>