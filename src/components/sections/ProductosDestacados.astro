---
import { getProductos, formatearPrecio, getImagenProducto } from '../../lib/woocommerce.js'

const base = import.meta.env.BASE_URL

// Obtener los primeros 8 productos (4 columnas x 2 filas)
const productos = await getProductos({ perPage: 8 })
---

<section class="py-20 bg-white">
  <div class="max-w-[1200px] mx-auto px-8">
    
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <p class="text-[#F47920] text-xs font-medium uppercase tracking-[0.2em] mb-4">
        Nuestros productos
      </p>
      <h2 class="text-[#0E2346] font-semibold mb-4">
        Productos destacados
      </h2>
      <p class="text-gray-600 font-light max-w-2xl mx-auto" style="font-size: 1.1rem; line-height: 1.7;">
        Instrumentación y componentes de alta calidad para la industria
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {productos.map((producto) => {
        const imagen = getImagenProducto(producto)
        const precio = formatearPrecio(producto.price)
        
        return (
          <a 
            href={`${base}productos/${producto.slug}`}
            class="group bg-white border border-gray-200 hover:border-[#F47920] transition-all duration-300 hover:shadow-lg"
          >
            {/* Imagen - más pequeña */}
            <div class="aspect-square bg-[#F5F5F0] p-4 flex items-center justify-center overflow-hidden">
              <img 
                src={imagen} 
                alt={producto.name}
                class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            
            {/* Info */}
            <div class="p-4">
              {/* Categoría */}
              {producto.categories && producto.categories.length > 0 && (
                <p class="text-[#F47920] text-xs font-medium uppercase tracking-wider mb-2">
                  {producto.categories[0].name}
                </p>
              )}
              
              {/* Nombre - más pequeño */}
              <h3 class="text-[#0E2346] font-semibold mb-2 line-clamp-2 group-hover:text-[#F47920] transition-colors" style="font-size: 0.95rem; line-height: 1.3;">
                {producto.name}
              </h3>
              
              {/* SKU */}
              {producto.sku && (
                <p class="text-gray-500 text-sm font-light mb-3">
                  SKU: {producto.sku}
                </p>
              )}
              
              {/* Precio */}
              <p class="text-[#0E2346] font-semibold" style="font-size: 1.3rem; letter-spacing: -0.01em;">
                {precio}
              </p>
              
              {/* Stock */}
              <div class="mt-4 pt-4 border-t border-gray-100">
                {producto.stock_status === 'instock' ? (
                  <span class="text-green-600 text-sm font-medium flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Disponible
                  </span>
                ) : (
                  <span class="text-red-600 text-sm font-medium">
                    Sin stock
                  </span>
                )}
              </div>
            </div>
          </a>
        )
      })}
    </div>

    {/* Botón ver todos */}
    <div class="text-center">
      <a 
        href="/productos" 
        class="inline-flex items-center gap-3 bg-[#F47920] hover:bg-[#d66a1a] text-white font-medium px-10 py-4 transition-colors"
      >
        Ver todos los productos
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
