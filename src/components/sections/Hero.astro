---
const base = import.meta.env.BASE_URL
---

<section class="relative bg-[#0E2346] min-h-[640px] flex items-center overflow-hidden">

  <!-- Fondo con imagen -->
  <div class="absolute inset-0">
    <!-- Imagen de fondo -->
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style={`background-image: url('${base}images/hero-bg.webp');`}></div>
    <!-- Overlay con gradiente: oscuro izquierda (texto), translúcido derecha (imagen visible) -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#0E2346]/95 via-[#0E2346]/70 to-[#0E2346]/30"></div>
    <!-- Acento naranja sutil -->
    <div class="absolute right-0 top-0 bottom-0 w-1/2 opacity-[0.05]" style="background: radial-gradient(circle at 80% 40%, #F47920, transparent 50%)"></div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 px-8 pt-24 pb-32 max-w-[1200px] mx-auto w-full">
    <div class="max-w-4xl">

      <!-- Eyebrow más presente -->
      <p class="text-[#F47920] text-xs font-medium uppercase tracking-[0.2em] mb-8">
        Instrumentación · Electrónica industrial
      </p>

      <!-- Título equilibrado -->
      <h1 class="text-white font-semibold mb-8" style="font-size: clamp(2.25rem, 5vw, 4.25rem); line-height: 1.08; letter-spacing: -0.025em;">
        Soluciones técnicas<br />
        de <span class="text-[#F47920]">alta precisión</span><br />
        para la industria.
      </h1>

      <!-- Subtítulo proporcionado -->
      <p class="text-white/75 font-light max-w-2xl mb-12" style="font-size: clamp(1.05rem, 1.3vw, 1.2rem); line-height: 1.7;">
        En Ramsy SPA integramos instrumentación, automatización y electrónica industrial para procesos críticos en minería, energía, agua y manufactura.
      </p>

      <!-- Botones más presentes -->
      <div class="flex gap-6 flex-wrap items-center">
        <a href={`${base}/productos`} class="bg-[#F47920] hover:bg-[#d96a10] text-white font-medium text-base tracking-wide px-10 py-5 transition-colors rounded-[2px]">
          Ver productos
        </a>
        <a href={`${base}/contacto`} class="inline-flex items-center gap-2.5 text-white font-normal text-base tracking-wide px-3 py-5 hover:gap-4 transition-all">
          Solicitar cotización
          <span class="text-[#F47920] text-lg">→</span>
        </a>
      </div>

    </div>
  </div>

</section>
