---
---

<section class="relative bg-[#0E2346] min-h-[640px] flex items-center overflow-hidden">

  <!-- Fondo decorativo -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0E2346] via-[#1B3A6B] to-[#0E2346]"></div>
    <div class="absolute right-0 top-0 bottom-0 w-2/3 opacity-[0.1]" style="background: radial-gradient(circle at 70% 40%, #F47920, transparent 60%)"></div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 px-8 pt-24 pb-32 max-w-[1400px] mx-auto w-full">
    <div class="max-w-4xl">

      <!-- Eyebrow más presente -->
      <p class="text-[#F47920] text-xs font-medium uppercase tracking-[0.2em] mb-8">
        Instrumentación · Electrónica industrial
      </p>

      <!-- Título equilibrado -->
      <h1 class="text-white font-semibold mb-8" style="font-size: clamp(2.25rem, 5vw, 4.25rem); line-height: 1.08; letter-spacing: -0.025em;">
        Soluciones técnicas<br />
        de <span class="text-[#F47920]">alta precisión</span><br />
        para la industria.
      </h1>

      <!-- Subtítulo proporcionado -->
      <p class="text-white/75 font-light max-w-2xl mb-12" style="font-size: clamp(1.05rem, 1.3vw, 1.2rem); line-height: 1.7;">
        En Ramsy SPA integramos instrumentación, automatización y electrónica industrial para procesos críticos en minería, energía, agua y manufactura.
      </p>

      <!-- Botones más presentes -->
      <div class="flex gap-6 flex-wrap items-center">
        <a href="/productos" class="bg-[#F47920] hover:bg-[#d96a10] text-white font-medium text-base tracking-wide px-10 py-5 transition-colors rounded-[2px]">
          Ver productos
        </a>
        <a href="/contacto" class="inline-flex items-center gap-2.5 text-white font-normal text-base tracking-wide px-3 py-5 hover:gap-4 transition-all">
          Solicitar cotización
          <span class="text-[#F47920] text-lg">→</span>
        </a>
      </div>

    </div>
  </div>

  <!-- Stats refinados pero más grandes -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-white/10 bg-black/15 backdrop-blur-sm">
    <div class="max-w-[1400px] mx-auto px-8 py-8 grid grid-cols-3 gap-8">
      <div>
        <p class="text-white font-semibold leading-none tracking-tight" style="font-size: clamp(1.5rem, 2.4vw, 2.15rem); letter-spacing: -0.02em;">+10</p>
        <p class="text-white/55 text-sm font-light mt-3 tracking-wide">Años de experiencia</p>
      </div>
      <div class="border-l border-white/10 pl-8">
        <p class="text-white font-semibold leading-none tracking-tight" style="font-size: clamp(1.5rem, 2.4vw, 2.15rem); letter-spacing: -0.02em;">100%</p>
        <p class="text-white/55 text-sm font-light mt-3 tracking-wide">Respaldo técnico</p>
      </div>
      <div class="border-l border-white/10 pl-8">
        <p class="text-white font-semibold leading-none tracking-tight" style="font-size: clamp(1.5rem, 2.4vw, 2.15rem); letter-spacing: -0.02em;">Chile</p>
        <p class="text-white/55 text-sm font-light mt-3 tracking-wide">Cobertura nacional</p>
      </div>
    </div>
  </div>

</section>
