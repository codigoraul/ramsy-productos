---
interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
  backgroundImage?: string
  title?: string
}

const { items, backgroundImage, title } = Astro.props
---

<nav 
  aria-label="Breadcrumb" 
  class="relative bg-[#0E2346] border-b border-gray-800 overflow-hidden flex items-center"
  style={backgroundImage ? `min-height: ${title ? '200px' : '100px'}` : ''}
>
  <!-- Imagen de fondo con overlay -->
  {backgroundImage && (
    <div class="absolute inset-0">
      <img 
        src={backgroundImage} 
        alt="" 
        class="w-full h-full object-cover opacity-40"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0E2346]/70 via-[#0E2346]/50 to-[#0E2346]/70"></div>
    </div>
  )}

  <div class="relative z-10 max-w-[1200px] mx-auto px-10 py-8 w-full">
    
    <!-- Título de página (opcional) -->
    {title && (
      <div class="mb-3">
        <h1 class="text-white font-semibold" style="font-size: 40px; line-height: 1.1; letter-spacing: -0.025em;">
          {title}
        </h1>
      </div>
    )}

    <!-- Breadcrumb -->
    <ol class="flex items-center gap-3 text-sm">
      {items.map((item, index) => (
        <li class="flex items-center gap-3">
          {item.href ? (
            <a 
              href={item.href} 
              class="text-white/70 hover:text-[#F47920] transition-colors font-light tracking-wide"
            >
              {item.label}
            </a>
          ) : (
            <span class="text-white font-medium tracking-wide">
              {item.label}
            </span>
          )}
          {index < items.length - 1 && (
            <svg class="w-4 h-4 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
