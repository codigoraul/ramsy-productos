---
const base = import.meta.env.BASE_URL
---

<footer class="bg-[#0E2346] text-white font-light">

  <!-- Contenido principal -->
  <div class="px-10 py-24 grid grid-cols-1 md:grid-cols-4 gap-14 max-w-[1200px] mx-auto">

    <!-- Columna 1: Marca -->
    <div class="md:col-span-1">
      <a href={base} class="inline-block mb-6">
        <img 
          src={`${base}/logo-blanco.png`} 
          alt="Ramsy" 
          class=" w-auto"
        />
      </a>
      <p class="text-white/55 font-light leading-[1.7] mb-8" style="font-size: 0.95rem;">
        Instrumentación y electrónica industrial. Soluciones técnicas confiables con más de 10 años de experiencia en Chile.
      </p>
      <!-- Redes sociales -->
      <div class="flex gap-2">
        <a href="#" class="w-9 h-9 border border-white/15 flex items-center justify-center text-white/50 hover:border-[#F47920] hover:text-[#F47920] transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="#" class="w-9 h-9 border border-white/15 flex items-center justify-center text-white/50 hover:border-[#F47920] hover:text-[#F47920] transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Columna 2: Productos -->
    <div>
      <h3 class="text-white text-sm font-medium uppercase tracking-[0.2em] mb-7">
        Productos
      </h3>
      <ul class="flex flex-col gap-3">
        {[
          { label: 'Instrumentación', href: `${base}/productos?cat=instrumentacion` },
          { label: 'Automatización', href: `${base}/productos?cat=automatizacion` },
          { label: 'Electrónica industrial', href: `${base}/productos?cat=electronica` },
          { label: 'Sensores', href: `${base}/productos?cat=sensores` },
          { label: 'Control de procesos', href: `${base}/productos?cat=control` },
        ].map(link => (
          <li>
            <a href={link.href} class="text-[15px] text-white/60 font-light hover:text-[#F47920] transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Columna 3: Servicios -->
    <div>
      <h3 class="text-white text-sm font-medium uppercase tracking-[0.2em] mb-7">
        Servicios
      </h3>
      <ul class="flex flex-col gap-3">
        {[
          { label: 'Asesoría técnica', href: `${base}/servicios` },
          { label: 'Mantenimiento', href: `${base}/servicios` },
          { label: 'Instalación', href: `${base}/servicios` },
          { label: 'Calibración', href: `${base}/servicios` },
        ].map(link => (
          <li>
            <a href={link.href} class="text-[15px] text-white/60 font-light hover:text-[#F47920] transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Columna 4: Contacto -->
    <div>
      <h3 class="text-white text-sm font-medium uppercase tracking-[0.2em] mb-7">
        Datos de contacto
      </h3>
      <ul class="flex flex-col gap-3.5">
        <li class="text-[15px] text-white/60 font-light leading-[1.6]">
          Las Madreselvas 5052<br />
          La Serena, Chile
        </li>
        <li class="text-[15px] text-white/60 font-light">
          RUT 77.958.882-3
        </li>
        <li>
          <a href="tel:+56900000000" class="text-[15px] text-white/60 font-light hover:text-[#F47920] transition-colors">
            +56 9 XXXX XXXX
          </a>
        </li>
        <li>
          <a href="mailto:contacto@ramsy.cl" class="text-[15px] text-white/60 font-light hover:text-[#F47920] transition-colors">
            contacto@ramsy.cl
          </a>
        </li>
      </ul>

      <a href={`${base}/contacto`} class="inline-flex items-center gap-2 mt-8 text-[13px] text-white font-normal hover:gap-3 transition-all border-b border-white/30 pb-1">
        Enviar mensaje
        <span class="text-[#F47920]">→</span>
      </a>
    </div>

  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/8">
    <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-2 max-w-[1200px] mx-auto">
      <p class="text-[13px] text-white/40 font-light tracking-wide">
        © {new Date().getFullYear()} Ramsy SPA. Todos los derechos reservados.
      </p>
      <p class="text-[13px] text-white/40 font-light tracking-wide">
        Instrumentación y electrónica industrial · La Serena, Chile
      </p>
    </div>
  </div>

</footer>
