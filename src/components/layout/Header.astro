---
import ContadorCarrito from '../ui/ContadorCarrito.jsx'
import { BotonBuscador } from '../ui/BuscadorModal.jsx'
import MenuMobile from '../ui/MenuMobile.jsx'

const base = import.meta.env.BASE_URL
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100">
  <!-- Top bar -->
  <div class="hidden md:block bg-[#F47920] text-white text-sm font-light py-3">
    <div class="max-w-[1200px] mx-auto px-10 flex justify-between items-center tracking-wide">
      <span>Lun – Vie · 09:00 – 18:00</span>
      <span>contacto@ramsy.cl &nbsp;·&nbsp; +56 9 XXXX XXXX</span>
    </div>
  </div>

  <!-- Nav principal -->
  <nav class="max-w-[1200px] mx-auto px-6 md:px-10 flex items-center gap-6 md:gap-12 h-16 md:h-24">

    <!-- Logo -->
    <a href={base} class="flex items-center gap-3 md:gap-4 flex-shrink-0">
      <img 
        src={`${base}logo-ramsy.svg`}
        alt="Ramsy" 
        class="w-24 md:w-[156px] h-auto"
      />
      <span class="hidden md:block text-[11px] font-light uppercase tracking-[0.15em] text-gray-400 border-l border-gray-200 pl-3 max-w-[130px] leading-tight">
        Instrumentación industrial
      </span>
    </a>

    <!-- Links navegación más grandes y legibles -->
    <ul class="hidden lg:flex items-center gap-10 list-none m-0 p-0 ml-auto">
      <li>
        <a href={base} class="text-[16px] font-medium tracking-wide text-gray-700 hover:text-[#0E2346] transition-colors py-2 relative group">
          Inicio
          <span class="absolute bottom-0 left-0 w-0 h-px bg-[#F47920] group-hover:w-full transition-all duration-300"></span>
        </a>
      </li>
      <li>
        <a href={`${base}/nosotros`} class="text-[16px] font-medium tracking-wide text-gray-700 hover:text-[#0E2346] transition-colors py-2 relative group">
          Nosotros
          <span class="absolute bottom-0 left-0 w-0 h-px bg-[#F47920] group-hover:w-full transition-all duration-300"></span>
        </a>
      </li>
      <li>
        <a href={`${base}/servicios`} class="text-[16px] font-medium tracking-wide text-gray-700 hover:text-[#0E2346] transition-colors py-2 relative group">
          Servicios
          <span class="absolute bottom-0 left-0 w-0 h-px bg-[#F47920] group-hover:w-full transition-all duration-300"></span>
        </a>
      </li>
      <li class="relative group">
        <a href={`${base}/productos`} class="inline-flex items-center gap-1.5 text-[16px] font-medium tracking-wide text-gray-700 hover:text-[#0E2346] transition-colors py-2">
          Productos
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <div class="hidden group-hover:block absolute top-full left-0 bg-white shadow-lg border-t-2 border-[#F47920] min-w-[240px] z-50 py-2">
          <a href={`${base}/productos?cat=instrumentacion`} class="block px-6 py-3.5 text-[14px] font-light text-gray-600 hover:bg-[#F5F5F0] hover:text-[#0E2346] transition-colors">
            Instrumentación
          </a>
          <a href={`${base}/productos?cat=automatizacion`} class="block px-6 py-3.5 text-[14px] font-light text-gray-600 hover:bg-[#F5F5F0] hover:text-[#0E2346] transition-colors">
            Automatización
          </a>
          <a href={`${base}/productos?cat=electronica`} class="block px-6 py-3.5 text-[14px] font-light text-gray-600 hover:bg-[#F5F5F0] hover:text-[#0E2346] transition-colors">
            Electrónica industrial
          </a>
        </div>
      </li>
      <li>
        <a href={`${base}/contacto`} class="text-[16px] font-medium tracking-wide text-gray-700 hover:text-[#0E2346] transition-colors py-2 relative group">
          Contacto
          <span class="absolute bottom-0 left-0 w-0 h-px bg-[#F47920] group-hover:w-full transition-all duration-300"></span>
        </a>
      </li>
    </ul>

    <!-- CTA -->
    <div class="hidden lg:flex items-center gap-4 pl-5 border-l border-gray-100">
      <BotonBuscador client:load />
      <ContadorCarrito client:load />
    </div>

    <!-- Menú móvil y carrito -->
    <div class="flex lg:hidden items-center gap-4 ml-auto">
      <BotonBuscador client:load />
      <ContadorCarrito client:load />
      <MenuMobile client:load />
    </div>

  </nav>
</header>
